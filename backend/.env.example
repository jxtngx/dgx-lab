# DGX Lab backend — copy to .env and adjust as needed

# Data directories (defaults work on a standard DGX Spark)
# DGX_LAB_MODELS_DIR=~/.cache/huggingface/hub
# DGX_LAB_EXPERIMENTS_DIR=~/.dgx-lab/experiments
# DGX_LAB_TRACES_DIR=~/.dgx-lab/traces
# DGX_LAB_DESIGNER_DIR=~/.dgx-lab/designer
# DGX_LAB_CURATOR_DIR=~/.dgx-lab/curator
# DGX_LAB_DATASETS_DIR=~/.dgx-lab/datasets

# data-designer library config (provider keys + model aliases)
# DATA_DESIGNER_HOME=~/.data-designer

# Cursor and Claude agent transcript paths
# DGX_LAB_AGENT_TRANSCRIPTS_DIR=~/.cursor/projects/<project-slug>/agent-transcripts
# DGX_LAB_CLAUDE_TRANSCRIPTS_DIR=~/.claude/projects

# Hardware constants (DGX Spark defaults; override for other hardware)
# DGX_LAB_MEMORY_TOTAL_GB=128
# DGX_LAB_MEMORY_BW_MAX_GBS=273

# HuggingFace token (required for gated models)
# HF_TOKEN=hf_...
